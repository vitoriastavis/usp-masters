# Carrega as bibliotecas necessarias para manipular planilhas do Excel e dados
library(openxlsx)
library(readxl)
library(dplyr)
library(writexl)
# Define os caminhos para os arquivos Excel
targets_path <- "mirnas_targets.xlsx"
mirnas_path <- "mirnas.xlsx"
genes_path <- "genes.xlsx"
# Le os dados das planilhas Excel
mirnas_targets <- read_excel(targets_path, sheet = 1)
