library(readr)
library(dplyr)
# Diretório contendo os arquivos .csv
directory <- "C:/Users/vitor/Documents/usp/usp-masters/data/stp"
# Lista para armazenar os dataframes
dataframes <- list()
# Lista de arquivos no diretório
files <- list.files(path = directory, pattern = "\\.csv$", full.names = TRUE)
# Percorre os arquivos
for (file_path in files) {
if (file.info(file_path)$size > 0) {
print(file_path)
df <- read_csv(file_path, show_col_types = FALSE)
dataframes[[length(dataframes) + 1]] <- df
} else {
cat("Arquivo vazio ignorado:", basename(file_path), "\n")
}
}
# Concatena todos os dataframes em um único
stp_result <- bind_rows(dataframes)
# Salva o resultado
write_csv(stp_result, file.path(directory, "stp-result.csv"))
