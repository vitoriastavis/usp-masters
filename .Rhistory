genes_interest <- read_excel(genes_path, sheet = 1)
targets_path
# Define os caminhos para os arquivos Excel
targets_path <- "selecao/mirnas_targets.xlsx"
mirnas_path <- "mirnas.xlsx"
genes_path <- "genes.xlsx"
# Le os dados das planilhas Excel
mirnas_targets <- read_excel(targets_path, sheet = 1)
# Define os caminhos para os arquivos Excel
targets_path <- "mirnas_targets.xlsx"
mirnas_path <- "mirnas.xlsx"
genes_path <- "genes.xlsx"
# Le os dados das planilhas Excel
mirnas_targets <- read_excel(targets_path, sheet = 1)
mirnas_interest <- read_excel(mirnas_path, sheet = 1)
genes_interest <- read_excel(genes_path, sheet = 1)
# Filtra os genes da tabela de mirnas_targets, mantendo apenas os que estao na lista de genes de interesse
filter_genes <- mirnas_targets %>%
filter(genesymbol %in% genes_interest[[1]])  # Filtra apenas os genes de interesse
View(filter_genes)
# Conta o numero de genes de interesse regulados por cada miRNA
counts <- filter_genes %>%
group_by(mirnaid) %>%
summarise(Count = n()) %>%  # Conta o numero de genes de interesse para cada miRNA
arrange(desc(Count))
# Calcular o terceiro quartil dos counts
q3 <- unname(quantile(counts$Count, 0.75))
# Seleciona os miRNAs que regulam mais genes do que o terceiro quartil
selected_mirnas <- counts %>%
filter(Count > q3)
selected_mirnas
# Checa se todos os genes da tabela 'genes_interest' estao em 'filter_genes'
all_interest_genes_present <- all(genes_interest[[1]] %in% filter_genes$genesymbol)
# Checa se ha genes que nao fazem parte dos de interesse
extra_genes <- setdiff(filter_genes$genesymbol, genes_interest[[1]])
# Exibe os resultados da checagem
if (all_interest_genes_present & length(extra_genes) == 0) {
cat("todos os genes de interesse foram filtrados corretamente e nao ha genes extras")
} else {
if (!all_interest_genes_present) {
cat("nem todos os genes de interesse foram filtrados")
}
if (length(extra_genes) > 0) {
cat("foram filtrados genes que nao sao de interesse")
cat(extra_genes)
}
}
# Filtra os miRNAs que estao na lista de miRNAs selecionados
filter_mirnas <- filter_genes %>%
filter(mirnaid %in% selected_mirnas$mirnaid)
selected_genes <- data.frame(unique(filter_mirnas$genesymbol))
colnames(selected_genes) <- c('genes')
# Cria a tabela com os genes-alvo, numero de miRNAs que os regulam, e quais miRNAs sao
interest_genes_mirnas <- filter_mirnas %>%
group_by(genesymbol) %>%
summarise(
n_mirnas = n_distinct(mirnaid),         # Numero de miRNAs distintos que regulam cada gene
mirnas = paste(unique(mirnaid), collapse = ", ")  # Lista dos miRNAs que regulam o gene
) %>%
arrange(desc(n_mirnas))
mean_genes <- mean(interest_genes_mirnas$n_mirnas)
core_genes <- interest_genes_mirnas %>%
filter(n_mirnas > mean_genes)
# Checa se todos os miRNAs de 'selected_mirnas' estao em 'filter_mirnas'
all_mirnas_present <- all(selected_mirnas$mirnaid %in% filter_mirnas$mirnaid)
# Checa se ha miRNAs que nao sao os acima do q3
extra_mirnas <- setdiff(filter_mirnas$mirnaid, selected_mirnas$mirnaid)
# Exibe os resultados da checagem
if (all_mirnas_present & length(extra_mirnas) == 0) {
print("todos os miRNAs selecionados (acima do q3) foram filtrados corretamente e nao ha miRNAs extras")
} else {
if (!all_mirnas_present) {
print("nem todos os miRNAs selecionados foram filtrados corretamente")
}
if (length(extra_mirnas) > 0) {
print("existem miRNAs extras que nao estao acima do q3")
print(extra_mirnas)
}
}
filter_mirnas
core_genes
View(core_genes)
View(selected_genes)
View(selected_mirnas)
View(filter_mirnas)
View(interest_genes_mirnas)
