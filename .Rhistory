# Conectar ao Ensembl
mart <- useMart("ensembl", dataset = "hsapiens_gene_ensembl")
# Converter UniProt ID para symbol (UniProtKB/Swiss-Prot ID -> Gene name)
uniprot_to_symbol <- getBM(
attributes = c("uniprot_swissprot", "uniprotswissprot", "hgnc_symbol"),
filters = "uniprot_swissprot",
values = stp_targets,
mart = mart
)
listAttributes()
uniprot_to_symbol <- getBM(
attributes = c("hgnc_symbol"),
filters = "uniprotswissprot",
values = stp_targets,
mart = mart
)
View(uniprot_to_symbol)
# Adiciona "_HUMAN" ao símbolo para comparar
uniprot_to_symbol$formatted_symbol <- paste0(uniprot_to_symbol$hgnc_symbol, "_HUMAN")
uniprot_to_symbol
stp_targets_hgnc <- uniprot_to_symbol$formatted_symbol
intersect(sea_targets, stp_targets_hgnc)
